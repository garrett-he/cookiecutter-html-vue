{
    "name": "{{ cookiecutter.project_slug }}",
    "version": "{{ cookiecutter.project_version }}",
    "description": "{{ cookiecutter.project_description }}",
    "private": {{ cookiecutter.project_private }},
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/{{ cookiecutter.github_path }}.git"
    },
    "keywords": [
        "{{ cookiecutter.project_keywords.split(',')|join('",\n"') }}"
    ],
    "author": "{{ cookiecutter.author_name }} <{{ cookiecutter.author_email }}>",
    "license": "{{ cookiecutter.license_id }}",
    "dependencies": {
    {% if cookiecutter.vue_version == '2' %}
        "vue": "^2.7.14",
        "vue-router": "^3.6.5"
        {%- if cookiecutter.with_vuex == 'yes' %}
        ,"vuex": "^3.6.2"
        {%- endif %}
    {% else %}
        "vue": "^3.3.4",
        "vue-router": "^4.2.2"
        {%- if cookiecutter.with_vuex == 'yes' %}
        ,"vuex": "^4.1.0"
        {%- endif %}
    {% endif %}
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^5.42.0",
        "@typescript-eslint/parser": "^5.42.0",
    {% if cookiecutter.vue_version == '2' %}
        "@vitejs/plugin-vue2": "^2.2.0",
        "@vue/test-utils": "^1.3.6",
    {% else %}
        "@vitejs/plugin-vue": "^4.2.3",
        "@vue/test-utils": "^2.3.2",
    {% endif %}
        "eslint": "^8.27.0",
        "husky": "^8.0.1",
        "jsdom": "^22.1.0",
        "markdownlint-cli": "^0.32.2",
        "stylelint": "^14.16.1",
        "stylelint-stylus": "^0.17.1",
        "stylus": "^0.59.0",
        "stylus-loader": "^7.1.3",
        "typescript": "^5.1.3",
        "vite": "^4.3.9",
        "vitest": "^0.32.5"
    }
}
